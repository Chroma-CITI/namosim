Panels:
  - Class: rviz/Displays
    Help Height: 83
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Simulator Knowledge1/Simulator Knowledge1/Namespaces1
        - /robot_011
        - /robot_011/Robot Knowledge1/Namespaces1
        - /robot_011/Robot Simulated Actions1/Namespaces1
      Splitter Ratio: 0.606060624
    Tree Height: 769
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.588679016
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: ""
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
